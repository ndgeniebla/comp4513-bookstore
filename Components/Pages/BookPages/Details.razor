@page "/books/details"
@using Microsoft.EntityFrameworkCore
@using comp4513_bookstore.Models
@inject IDbContextFactory<comp4513_bookstore.Data.BookstoreDb> DbFactory
@inject NavigationManager NavigationManager
@inject OrderState OrderState
@rendermode InteractiveServer

<PageTitle>Bookstore - Details - @(book != null ? book.Title : "Loading...")</PageTitle>

<h1>@(book != null ? book.Title : "Loading...")</h1>

<div class="row">
    <div class="col-md-8">
        @if (book is null) {
            <p>Loading...</p>
        }
        else {
            <div class="row">
                <div class="col-sm-4">
                    <img src="@book.CoverImageUrl" alt="@book.Title" class="img-fluid w-100 object-fit-cover" />
                </div>

                <div class="col-sm-8 position-relative">
                    <dl class="row">
                        <dt class="col-sm-4">Title</dt>
                        <dd class="col-sm-8">@book.Title</dd>
                        <dt class="col-sm-4">Author</dt>
                        <dd class="col-sm-8">@book.Author</dd>
                        <dt class="col-sm-4">Genre</dt>
                        <dd class="col-sm-8">@book.Genre</dd>
                        <dt class="col-sm-4">Publisher</dt>
                        <dd class="col-sm-8">@book.Publisher</dd>
                        <dt class="col-sm-4">PublicationYear</dt>
                        <dd class="col-sm-8">@book.PublicationYear</dd>
                        <dt class="col-sm-4">Language</dt>
                        <dd class="col-sm-8">@book.Language</dd>
                        <dt class="col-sm-4">PageCount</dt>
                        <dd class="col-sm-8">@book.PageCount</dd>
                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8">@book.Price</dd>
                    </dl>
                    <div>
                        <a href="@($"/books/edit?id={book.Id}")">Edit</a> |
                        <a href="@($"/")">Back to List</a>
                    </div>

                    <div class="position-absolute bottom-0">
                        <button class="btn btn-warning" @onclick="() => AddToCart(book)">Purchase</button>
                    </div>
                </div>
            </div>
        }
    </div>
    @* <h2>Book</h2> *@
    @* <hr /> *@
    @if (book is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        
    }
</div>

@if (recommendedBooks is not null && recommendedBooks.Count > 0)
{
    <div class="mt-5">
        <h6 class="fw-bold">Customers who bought this item also bought</h6>
        <div class="d-flex flex-wrap gap-3">
            @foreach (var rec in recommendedBooks)
            {
                <BookCard Book="rec" />
            }
        </div>
    </div>
}

@code {
    private Book? book;
    private List<Book>? recommendedBooks;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        book = await context.Books.FirstOrDefaultAsync(m => m.Id == Id);
        
        if (book is null)
        {
            NavigationManager.NotFound();
            return;
        }


        //find orders that have the chosen book, then select the books that aren't the chosen book
        var orderIdsWithThisBook = await context.Orders
            .Where(o => o.OrderItems.Any(oi => oi.Book.Id == Id))
            .Select(o => o.Id)
            .ToListAsync();

        //get recommended books
        var recommendedBookIds = await context.Orders
            .Where(o => orderIdsWithThisBook.Contains(o.Id))
            .SelectMany(o => o.OrderItems)
            .Select(oi => oi.Book.Id)
            .Where(bookId => bookId != Id)
            .Distinct()
            .ToListAsync();


        //populate list
        recommendedBooks = await context.Books
            .Where(b => recommendedBookIds.Contains(b.Id))
            .ToListAsync();
    }

    private void AddToCart(Book book) {
        OrderState.AddItem(new OrderItem {Book = book, Quantity = 1 });
    }
}